	<queryString language="SQL">
		<![CDATA[SELECT sistempenggajiankaryawan.karyawan.id_karyawan,
	sistempenggajiankaryawan.karyawan.nm_karyawan,
	sistempenggajiankaryawan.karyawan.jk,
	sistempenggajiankaryawan.karyawan.alamat,
	sistempenggajiankaryawan.karyawan.telp,
	sistempenggajiankaryawan.jabatan.nm_jabatan
FROM sistempenggajiankaryawan.karyawan
	INNER JOIN sistempenggajiankaryawan.jabatan ON 
	 sistempenggajiankaryawan.karyawan.id_jabatan = sistempenggajiankaryawan.jabatan.id_jabatan]]>
	</queryString>
