	<queryString language="SQL">
		<![CDATA[SELECT sistempenggajiankaryawan.tb_penggajian.id_gaji,
	sistempenggajiankaryawan.tb_penggajian.id_karyawan,
	sistempenggajiankaryawan.jabatan.nm_jabatan,
	sistempenggajiankaryawan.karyawan.nm_karyawan,
	sistempenggajiankaryawan.tb_penggajian.bulan,
	sistempenggajiankaryawan.tb_penggajian.tahun,
	sistempenggajiankaryawan.tb_penggajian.tanggal_gaji,
	sistempenggajiankaryawan.tb_penggajian.gaji_pokok,
	sistempenggajiankaryawan.tb_penggajian.tunjangan,
	sistempenggajiankaryawan.tb_penggajian.potongan,
	sistempenggajiankaryawan.tb_penggajian.total_gaji
FROM sistempenggajiankaryawan.tb_penggajian
	INNER JOIN sistempenggajiankaryawan.karyawan ON 
	 sistempenggajiankaryawan.tb_penggajian.id_karyawan = sistempenggajiankaryawan.karyawan.id_karyawan 
	INNER JOIN sistempenggajiankaryawan.jabatan ON 
	 sistempenggajiankaryawan.karyawan.id_jabatan = sistempenggajiankaryawan.jabatan.id_jabatan 
	LEFT JOIN sistempenggajiankaryawan.tunjangan ON 
	 sistempenggajiankaryawan.tb_penggajian.id_tunjangan = sistempenggajiankaryawan.tunjangan.id_tunjangan 
	LEFT JOIN sistempenggajiankaryawan.tb_potongan ON 
	 sistempenggajiankaryawan.tb_penggajian.id_potongan = sistempenggajiankaryawan.tb_potongan.id_potongan
	ORDER BY sistempenggajiankaryawan.tb_penggajian.id_gaji ASC;]]>
	</queryString>
