	<style name="Detail" fontName="Arial" fontSize="12"/>
	<queryString language="SQL">
		<![CDATA[SELECT
    CONCAT(bulan, ' ', tahun) AS bulan,
    SUM(total_gaji) AS total_gaji
	FROM tb_penggajian
	GROUP BY bulan, tahun
	ORDER BY tahun,
	FIELD(bulan,
	'Januari',
	'Februari',
	'Maret',
	'April',
	'Mei',
	'Juni',
	'Juli',
	'Agustus',
	'September',
	'Oktober',
	'November',
	'Desember');]]>
	</queryString>
	<field name="bulan" class="java.lang.String">
		<property name="com.jaspersoft.studio.field.name" value="bulan"/>
		<property name="com.jaspersoft.studio.field.label" value="bulan"/>
	</field>
	<field name="total_gaji" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="total_gaji"/>
		<property name="com.jaspersoft.studio.field.label" value="total_gaji"/>
	</field>
	<variable name="totalgaji" class="java.lang.String">
		<variableExpression><![CDATA["Rp " + String.format("%,.0f", $F{total_gaji})]]></variableExpression>
	</variable>
